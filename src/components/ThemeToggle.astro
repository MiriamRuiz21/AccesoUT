<button id="theme-toggle" class="theme-switch" aria-label="Cambiar modo de iluminación">
  <div class="switch-track">
    <div class="switch-handle">
      <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"></circle>
        <line x1="12" y1="1" x2="12" y2="3"></line>
        <line x1="12" y1="21" x2="12" y2="23"></line>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
        <line x1="1" y1="12" x2="3" y2="12"></line>
        <line x1="21" y1="12" x2="23" y2="12"></line>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
      </svg>
      <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
    </div>
  </div>
</button>

<style>
  .theme-switch {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    transition: transform 0.2s;
  }

  .theme-switch:hover {
    transform: scale(1.05);
  }

  .theme-switch:active {
    transform: scale(0.95);
  }

  .switch-track {
    width: 52px;
    height: 28px;
    background: linear-gradient(135deg, var(--color-navy-deep, #0D1B2A), var(--color-navy, #1B2A4A));
    border-radius: 20px;
    position: relative;
    padding: 3px;
    transition: background 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    box-shadow: inset 0 1px 3px rgba(0,0,0,0.3);
  }

  .switch-handle {
    width: 22px;
    height: 22px;
    background: linear-gradient(135deg, var(--color-accent, #00A688), var(--color-accent-light, #00C9A4));
    border-radius: 50%;
    position: absolute;
    left: 3px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
                background 0.3s;
    box-shadow: 0 1px 4px rgba(0,0,0,0.2), 0 0 8px rgba(0,166,136,0.2);
  }

  :global([data-theme="dark"]) .switch-track {
    background: linear-gradient(135deg, #0B1120, #162032);
  }

  :global([data-theme="dark"]) .switch-handle {
    transform: translateX(24px);
    background: linear-gradient(135deg, #94A3B8, #64748B);
    box-shadow: 0 1px 4px rgba(0,0,0,0.3);
  }

  .sun-icon, .moon-icon {
    width: 13px;
    height: 13px;
    color: #fff;
  }

  .moon-icon { display: none; }

  :global([data-theme="dark"]) .sun-icon { display: none; }
  :global([data-theme="dark"]) .moon-icon { display: block; }
</style>

<script>
  const toggle = document.getElementById('theme-toggle');
  const doc = document.documentElement;

  const savedTheme = localStorage.getItem('theme') || 'light';
  doc.setAttribute('data-theme', savedTheme);

  toggle?.addEventListener('click', () => {
    const isDark = doc.getAttribute('data-theme') === 'dark';
    const newTheme = isDark ? 'light' : 'dark';
    
    doc.setAttribute('data-theme', newTheme);
    localStorage.setItem('theme', newTheme);
  });
</script>
