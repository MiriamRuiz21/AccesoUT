---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Banner from '../components/Banner.astro';
import ImageCarousel from '../components/ImageCarousel.astro';
import ChatWidget from '../components/ChatWidget.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Directorio — UTSJR">
  <Header />

  <main>
    <Banner />

    <ImageCarousel />

    <section class="directorio-info container reveal">
      <h2>Directorio Institucional</h2>
      <p class="directorio-desc">
        Consulta el directorio completo de la Universidad Tecnológica de San Juan del Río 
        para comunicarte con las áreas que necesites.
      </p>

      <div class="directorio-grid">
        <div class="dir-card">
          <div class="dir-icon">📞</div>
          <h3>Conmutador General</h3>
          <p>(427) 129 20 00</p>
        </div>

        <div class="dir-card">
          <div class="dir-icon">📧</div>
          <h3>Correo Institucional</h3>
          <p>contacto@utsjr.edu.mx</p>
        </div>

        <div class="dir-card">
          <div class="dir-icon">📍</div>
          <h3>Dirección</h3>
          <p>Av. La Palma No. 125, Col. Vista Hermosa<br/>San Juan del Río, Qro. C.P. 76826</p>
        </div>

        <div class="dir-card">
          <div class="dir-icon">🌐</div>
          <h3>Directorio Completo</h3>
          <a href="https://www.utsjr.edu.mx/directorio.php" target="_blank" class="btn btn-outline">
            Ver en portal UTSJR
          </a>
        </div>
      </div>
    </section>
  </main>

  <ChatWidget />
  <Footer />
</Layout>

<style>
  .directorio-info {
    padding: 50px 0;
    text-align: center;
  }

  .directorio-info h2 {
    margin-bottom: 10px;
  }

  .directorio-desc {
    max-width: 600px;
    margin: 0 auto 40px;
    font-size: 1rem;
    color: var(--color-text-light);
    line-height: 1.7;
  }

  .directorio-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .dir-card {
    background: var(--color-card, #fff);
    border: 1px solid var(--color-border, #e2e8f0);
    border-radius: var(--radius-md);
    padding: 28px 20px;
    text-align: center;
    transition: var(--transition);
  }

  .dir-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-accent-light);
  }

  .dir-icon {
    font-size: 2.2rem;
    margin-bottom: 12px;
  }

  .dir-card h3 {
    font-size: 0.95rem;
    color: var(--color-primary);
    margin-bottom: 8px;
    -webkit-text-fill-color: var(--color-primary);
    background: none;
  }

  .dir-card p {
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .dir-card .btn {
    margin-top: 8px;
    font-size: 0.82rem;
    padding: 8px 18px;
  }

  @media (max-width: 900px) {
    .directorio-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 560px) {
    .directorio-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
