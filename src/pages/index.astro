---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Banner from '../components/Banner.astro';
import ChatWidget from '../components/ChatWidget.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Centro de Acceso UTSJR">
  <Header />

  <main>
    <Banner />

    <section class="welcome-container reveal">
      <h1 class="welcome-title">Bienvenid@ al Centro de Acceso <strong>UTSJR</strong></h1>

      <div class="cards-wrapper">
        <a href="/solicitud-cita" class="welcome-card">
          <div class="icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <circle cx="12" cy="14" r="3"></circle>
              <path d="M12 17v4"></path>
            </svg>
          </div>
          <span class="card-label">Nuevo Registro<br/><strong>Visitante</strong></span>
        </a>

        <div class="vertical-divider"></div>

        <a href="/consultar-visita" class="welcome-card">
          <div class="icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              <line x1="8" y1="11" x2="14" y2="11"></line>
              <line x1="11" y1="8" x2="11" y2="14"></line>
            </svg>
          </div>
          <span class="card-label">Consultar<br/><strong>Visita</strong></span>
        </a>
      </div>

      <p class="welcome-footer">
        El Servicio de Administración Universitaria gestiona con piso parejo, vocación humana y conciencia social para la transformación de la UTSJR.
      </p>
    </section>
  </main>

  <ChatWidget />
  <Footer />
</Layout>

<style>
  /* BIENVENIDA */
  .welcome-container {
    text-align: center;
    padding: 50px 20px;
    max-width: 900px;
    margin: 0 auto;
  }

  .welcome-title {
    font-size: 2.2rem;
    color: var(--color-text, #2D3748);
    margin-bottom: 40px;
    font-family: var(--font-heading, 'Outfit', sans-serif);
    -webkit-text-fill-color: var(--color-text, #2D3748);
    background: none;
  }

  .welcome-title strong {
    color: var(--color-accent, #00A688);
    -webkit-text-fill-color: var(--color-accent, #00A688);
  }

  [data-theme="dark"] .welcome-title {
    color: var(--text-color);
  }

  .cards-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 30px;
    margin-bottom: 40px;
  }

  .welcome-card {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 25px;
    border: 1px solid var(--divider, #ccc);
    border-radius: var(--radius-md, 12px);
    width: 200px;
    height: 210px;
    background: var(--card-bg, #fff);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease, background 0.25s ease;
    cursor: pointer;
  }

  .welcome-card:hover {
    transform: translateY(-6px) scale(1.03);
    border-color: var(--color-accent);
    box-shadow: 0 12px 28px rgba(0, 166, 136, 0.18);
    background: var(--color-accent-glow, rgba(0, 166, 136, 0.04));
  }

  .welcome-card:hover .icon-box svg {
    color: var(--utsjr-green) !important;
    transform: scale(1.2) rotate(-5deg);
  }

  .welcome-card:hover .card-label {
    color: var(--utsjr-green);
  }

  .icon-box {
    width: 50px;
    height: 50px;
    margin-bottom: 10px;
  }

  .icon-box svg {
    width: 100%;
    height: 100%;
    color: var(--text-muted, #666);
    transition: transform 0.3s ease, color 0.3s ease;
  }

  .card-label {
    transition: color 0.25s ease;
    color: var(--text-color, #444);
    text-align: center;
    font-size: 0.95rem;
  }

  .vertical-divider {
    width: 2px;
    height: 100px;
    background: var(--gradient-separator, linear-gradient(to bottom, #003057, #00A688));
    opacity: 0.6;
    border-radius: 2px;
  }

  .welcome-footer {
    max-width: 700px;
    margin: 0 auto;
    font-size: 0.95rem;
    line-height: 1.7;
  }

  /* RESPONSIVO */
  @media (max-width: 900px) {
    .cards-wrapper {
      flex-direction: column;
    }

    .vertical-divider {
      display: none;
    }
  }
</style>
