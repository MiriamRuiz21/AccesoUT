---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Banner from '../components/Banner.astro';
import ChatWidget from '../components/ChatWidget.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Consultar Visita — UTSJR">
  <Header />

  <main>
    <Banner />

    <section class="lookup-container container reveal">
      <div class="lookup-card">
        <div class="lookup-header">
          <div class="lookup-icon"><i class="fas fa-search"></i></div>
          <h2>Consultar mis Visitas</h2>
          <p>Ingresa tu correo electrónico para ver el estado de tus visitas registradas.</p>
        </div>

        <div class="search-row">
          <input type="email" id="correoInput" placeholder="tu@correo.com" />
          <button class="btn-buscar" id="buscarBtn">
            <i class="fas fa-search"></i> Buscar
          </button>
        </div>

        <div id="alertBox" class="alert-box" style="display:none"></div>
      </div>

    </section>
  </main>

  <!-- Modal de resultados de visitas -->
  <div class="visitas-modal-overlay" id="visitasModal">
    <div class="visitas-modal">
      <div class="visitas-modal-header">
        <h3><i class="fas fa-clipboard-list"></i> Mis Visitas</h3>
        <button class="modal-close-btn" id="cerrarVisitasModal">
          <i class="fas fa-times"></i>
        </button>
      </div>
      <div class="visitas-modal-body" id="visitasModalBody">
        <!-- Contenido dinámico -->
      </div>
      <div class="visitas-modal-footer">
        <button class="btn-cerrar-visitas" id="cerrarVisitasBtn">
          <i class="fas fa-times-circle"></i> Cerrar
        </button>
      </div>
    </div>
  </div>

  <ChatWidget />
  <Footer />
</Layout>

<style>
  .lookup-container {
    padding: 3rem 0;
    max-width: 750px;
    margin: 0 auto;
  }

  .lookup-card {
    background: var(--color-card, #fff);
    border: 1px solid var(--color-border, #eee);
    border-radius: var(--radius-lg, 16px);
    padding: 40px;
    box-shadow: var(--shadow-md);
  }

  .lookup-header {
    text-align: center;
    margin-bottom: 28px;
  }

  .lookup-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--gradient-button, linear-gradient(135deg, #00A688, #00C9A4));
    color: white;
    font-size: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
    box-shadow: var(--shadow-accent);
  }

  .lookup-header h2 {
    color: var(--color-primary);
    margin-bottom: 8px;
    -webkit-text-fill-color: var(--color-primary);
    background: none;
  }

  .lookup-header p {
    color: var(--color-text-light, #718096);
    font-size: 0.95rem;
  }

  .search-row {
    display: flex;
    gap: 12px;
  }

  .search-row input {
    flex: 1;
    margin-bottom: 0;
  }

  .btn-buscar {
    padding: 12px 24px;
    border: none;
    border-radius: var(--radius-sm, 8px);
    background: linear-gradient(135deg, #00A688, #00C9A4);
    color: white;
    font-family: var(--font-heading, 'Outfit', sans-serif);
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 14px rgba(0, 166, 136, 0.25);
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .btn-buscar:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 166, 136, 0.4);
  }

  .btn-buscar:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  /* Alert */
  .alert-box {
    padding: 12px 16px;
    border-radius: var(--radius-sm, 8px);
    margin-top: 16px;
    font-size: 0.9rem;
  }

  .alert-box.alert-error {
    background: rgba(220, 53, 69, 0.1);
    color: #dc3545;
    border: 1px solid rgba(220, 53, 69, 0.25);
  }

  .alert-box.alert-info {
    background: rgba(0, 166, 136, 0.08);
    color: var(--color-accent, #00A688);
    border: 1px solid rgba(0, 166, 136, 0.2);
  }

  /* ── Modal de Visitas ── */
  .visitas-modal-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(6px);
    z-index: 99999;
    justify-content: center;
    align-items: center;
    padding: 20px;
  }

  .visitas-modal-overlay.activo {
    display: flex;
  }

  .visitas-modal {
    background: var(--color-card, #fff);
    border-radius: var(--radius-lg, 16px);
    max-width: 560px;
    width: 100%;
    max-height: 85vh;
    display: flex;
    flex-direction: column;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.25);
    animation: modalSlideIn 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    overflow: hidden;
  }

  @keyframes modalSlideIn {
    from { opacity: 0; transform: scale(0.9) translateY(30px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .visitas-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 28px;
    background: linear-gradient(135deg, #0F4C75, #0D1B2A);
    color: white;
  }

  .visitas-modal-header h3 {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 700;
    color: white;
    -webkit-text-fill-color: white;
    background: none;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .modal-close-btn {
    background: rgba(255,255,255,0.15);
    border: none;
    color: white;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    font-size: 0.95rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.25s ease;
  }

  .modal-close-btn:hover {
    background: rgba(255,255,255,0.3);
    transform: rotate(90deg);
  }

  .visitas-modal-body {
    padding: 24px 28px;
    overflow-y: auto;
    flex: 1;
  }

  .visitas-modal-footer {
    padding: 16px 28px;
    border-top: 1px solid var(--color-border, #eee);
    text-align: center;
  }

  .btn-cerrar-visitas {
    padding: 10px 32px;
    border: none;
    border-radius: var(--radius-sm, 8px);
    background: linear-gradient(135deg, #0F4C75, #0D1B2A);
    color: white;
    font-family: var(--font-heading, 'Outfit', sans-serif);
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .btn-cerrar-visitas:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(15, 76, 117, 0.35);
  }

  /* ── Visita Card dentro del modal ── */
  .visita-card {
    background: var(--color-bg-warm, #FAFBFD);
    border: 1px solid var(--color-border, #eee);
    border-radius: var(--radius-md, 12px);
    padding: 20px;
    margin-bottom: 16px;
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .visita-card:last-child {
    margin-bottom: 0;
  }

  .visita-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  /* Barra lateral de estado */
  .visita-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 5px;
    height: 100%;
    border-radius: 12px 0 0 12px;
  }

  .visita-card.pendiente::before  { background: linear-gradient(180deg, #f59e0b, #d97706); }
  .visita-card.aprobada::before   { background: linear-gradient(180deg, #10b981, #059669); }
  .visita-card.cancelada::before  { background: linear-gradient(180deg, #ef4444, #dc2626); }
  .visita-card.finalizada::before { background: linear-gradient(180deg, #6b7280, #4b5563); }

  /* Icono grande de estado */
  .estado-icon-big {
    text-align: center;
    margin-bottom: 12px;
  }

  .estado-icon-big i {
    font-size: 2.2rem;
  }

  .estado-icon-big.pendiente i  { color: #f59e0b; }
  .estado-icon-big.aprobada i   { color: #10b981; }
  .estado-icon-big.cancelada i  { color: #ef4444; }
  .estado-icon-big.finalizada i { color: #6b7280; }

  .visita-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
    padding-left: 8px;
  }

  .visita-depto {
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-primary, #0F4C75);
  }

  .badge-estado {
    padding: 5px 16px;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .badge-estado.pendiente  { background: #fef3c7; color: #92400e; }
  .badge-estado.aprobada   { background: #d1fae5; color: #065f46; }
  .badge-estado.cancelada  { background: #fee2e2; color: #991b1b; }
  .badge-estado.finalizada { background: #f3f4f6; color: #374151; }

  .visita-info {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    font-size: 0.88rem;
    padding-left: 8px;
  }

  .visita-info-item {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .visita-info-item strong {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted, #A0AEC0);
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .visita-info-item strong i {
    font-size: 0.72rem;
    color: var(--color-accent, #00A688);
  }

  .visita-info-item span {
    color: var(--color-text, #333);
    font-weight: 500;
  }

  /* Separador entre visitas */
  .visita-separator {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border, #eee), transparent);
    margin: 8px 0;
  }

  .btn-resend {
    margin-top: 14px;
    padding: 8px 18px;
    background: transparent;
    color: var(--color-accent, #00A688);
    border: 2px solid var(--color-accent, #00A688);
    border-radius: var(--radius-sm, 8px);
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-left: 8px;
  }

  .btn-resend:hover {
    background: var(--color-accent, #00A688);
    color: white;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(0, 166, 136, 0.3);
  }

  .btn-resend:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  .empty-state {
    text-align: center;
    padding: 40px 20px;
  }

  .empty-state i {
    font-size: 3.5rem;
    margin-bottom: 16px;
    display: block;
    color: var(--color-text-muted, #A0AEC0);
    opacity: 0.35;
  }

  .empty-state p {
    color: var(--color-text-muted, #A0AEC0);
    font-size: 0.95rem;
  }

  /* Contador de visitas */
  .visitas-count {
    text-align: center;
    margin-bottom: 18px;
    font-size: 0.85rem;
    color: var(--color-text-light, #718096);
  }

  .visitas-count strong {
    color: var(--color-accent, #00A688);
  }

  @media (max-width: 576px) {
    .search-row {
      flex-direction: column;
    }
    .visitas-modal {
      max-height: 90vh;
    }
    .visita-info {
      grid-template-columns: 1fr;
    }
    .visita-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }
</style>

<script>
  import { endpoints } from '../config/api.js';

  function initLookup() {
    const buscarBtn = document.getElementById('buscarBtn') as HTMLButtonElement;
    const correoInput = document.getElementById('correoInput') as HTMLInputElement;
    const alertBox = document.getElementById('alertBox');

    // Modal elements
    const modal = document.getElementById('visitasModal');
    const modalBody = document.getElementById('visitasModalBody');
    const cerrarModalBtn = document.getElementById('cerrarVisitasModal');
    const cerrarModalFooter = document.getElementById('cerrarVisitasBtn');

    function abrirModal() {
      modal?.classList.add('activo');
      document.body.style.overflow = 'hidden';
    }

    function cerrarModal() {
      modal?.classList.remove('activo');
      document.body.style.overflow = '';
    }

    cerrarModalBtn?.addEventListener('click', cerrarModal);
    cerrarModalFooter?.addEventListener('click', cerrarModal);
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) cerrarModal();
    });

    function formatFecha(iso: string) {
      return new Date(iso).toLocaleDateString('es-MX', {
        weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
        timeZone: 'America/Mexico_City'
      });
    }

    function getEstadoIcon(estado: string) {
      switch (estado) {
        case 'aprobada':   return 'fa-check-circle';
        case 'pendiente':  return 'fa-clock';
        case 'cancelada':  return 'fa-times-circle';
        case 'finalizada': return 'fa-flag-checkered';
        default:           return 'fa-question-circle';
      }
    }

    function showAlert(msg: string, type: string) {
      if (!alertBox) return;
      alertBox.className = `alert-box alert-${type}`;
      alertBox.textContent = msg;
      alertBox.style.display = 'block';
    }

    function renderVisitas(visitas: any[], correo: string) {
      if (!modalBody) return;

      if (visitas.length === 0) {
        modalBody.innerHTML = `
          <div class="empty-state">
            <i class="fas fa-inbox"></i>
            <p>No se encontraron visitas registradas para este correo.</p>
          </div>`;
        abrirModal();
        return;
      }

      const countHTML = `<div class="visitas-count">Se encontraron <strong>${visitas.length}</strong> visita${visitas.length > 1 ? 's' : ''} registrada${visitas.length > 1 ? 's' : ''}</div>`;

      const cards = visitas.map((v: any) => `
        <div class="visita-card ${v.estado}">
          <div class="estado-icon-big ${v.estado}">
            <i class="fas ${getEstadoIcon(v.estado)}"></i>
          </div>
          <div class="visita-header">
            <span class="visita-depto">${v.Departamentos?.nombre || 'Sin departamento'}</span>
            <span class="badge-estado ${v.estado}">${v.estado.charAt(0).toUpperCase() + v.estado.slice(1)}</span>
          </div>
          <div class="visita-info">
            <div class="visita-info-item">
              <strong><i class="fas fa-calendar-alt"></i> Fecha</strong>
              <span>${formatFecha(v.fecha)}</span>
            </div>
            <div class="visita-info-item">
              <strong><i class="fas fa-clock"></i> Hora</strong>
              <span>${v.hora_inicio}</span>
            </div>
            <div class="visita-info-item">
              <strong><i class="fas fa-map-marker-alt"></i> Ubicacion</strong>
              <span>${v.Departamentos?.ubicacion || 'N/A'}</span>
            </div>
            <div class="visita-info-item">
              <strong><i class="fas fa-comment"></i> Motivo</strong>
              <span>${v.motivo}</span>
            </div>
          </div>
          ${v.estado === 'aprobada' ? `
            <button class="btn-resend" data-id="${v.id}" data-correo="${correo}">
              <i class="fas fa-qrcode"></i> Reenviar QR a mi correo
            </button>
          ` : ''}
        </div>
      `).join('');

      modalBody.innerHTML = countHTML + cards;

      // Eventos de reenvio QR
      modalBody.querySelectorAll('.btn-resend').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const button = btn as HTMLButtonElement;
          button.disabled = true;
          button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Enviando...';
          try {
            const res = await fetch(endpoints.resendQR, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'ngrok-skip-browser-warning': 'true'
              },
              body: JSON.stringify({
                visita_id: Number(button.dataset.id),
                correo: button.dataset.correo
              })
            });
            if (res.ok) {
              button.innerHTML = '<i class="fas fa-check" style="color:#10b981"></i> QR enviado';
              button.style.borderColor = '#10b981';
              button.style.color = '#10b981';
            } else {
              button.innerHTML = '<i class="fas fa-times"></i> Error al enviar';
              button.style.borderColor = '#ef4444';
              button.style.color = '#ef4444';
            }
          } catch {
            button.innerHTML = '<i class="fas fa-times"></i> Error de conexion';
            button.style.borderColor = '#ef4444';
            button.style.color = '#ef4444';
          }
        });
      });

      abrirModal();
    }

    async function buscar() {
      const correo = correoInput?.value.trim();
      if (!correo) {
        showAlert('Ingresa tu correo electronico.', 'error');
        return;
      }

      if (buscarBtn) {
        buscarBtn.disabled = true;
        buscarBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Buscando...';
      }
      if (alertBox) alertBox.style.display = 'none';

      try {
        const res = await fetch(`${endpoints.lookup}?correo=${encodeURIComponent(correo)}`, {
          headers: { 'ngrok-skip-browser-warning': 'true' }
        });
        const json = await res.json();

        if (res.ok) {
          renderVisitas(json.data, correo);
        } else {
          showAlert(`Error: ${json.error}`, 'error');
        }
      } catch {
        showAlert('Error de conexion con el servidor.', 'error');
      } finally {
        if (buscarBtn) {
          buscarBtn.disabled = false;
          buscarBtn.innerHTML = '<i class="fas fa-search"></i> Buscar';
        }
      }
    }

    buscarBtn?.addEventListener('click', buscar);
    correoInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') buscar();
    });
  }

  document.addEventListener('DOMContentLoaded', initLookup);
  document.addEventListener('astro:page-load', initLookup);
</script>
