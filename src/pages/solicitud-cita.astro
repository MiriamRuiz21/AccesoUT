---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Banner from '../components/Banner.astro';
import ChatWidget from '../components/ChatWidget.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Solicitud de Cita — UTSJR">
  <Header />

  <main>
    <Banner />

    <section class="form-container container reveal">
      <div class="card-grid">
        <div class="form-side">
          <h2>Solicitud de Cita / Acceso</h2>
          <p>Completa tus datos para agendar tu visita al campus.</p>
          
          <form id="appointment-form">
            <p class="section-label"><i class="fas fa-user"></i> Datos Personales</p>

            <div class="form-row">
              <input type="text" name="nombre" placeholder="Nombre(s)" required />
              <input type="text" name="apellido_paterno" placeholder="Apellido Paterno" required />
            </div>

            <div class="form-row">
              <input type="text" name="apellido_materno" placeholder="Apellido Materno" />
              <input type="email" name="correo" placeholder="Correo electrónico" required />
            </div>

            <div class="form-row">
              <input type="tel" name="telefono" placeholder="Teléfono (10 dígitos)" required />
            </div>

            <p class="section-label"><i class="fas fa-building"></i> Detalles de la Visita</p>

            <div class="input-group">
              <label for="depto_id">Departamento a visitar:</label>
              <select name="depto_id" id="depto_id" required>
                <option value="" disabled selected>Cargando departamentos...</option>
              </select>
            </div>

            <div class="form-row">
              <div class="input-group">
                <label for="fecha">Fecha de cita (Lunes a Viernes):</label>
                <input type="date" name="fecha" id="fecha" required />
                <span id="date-error" style="color: #d9534f; font-size: 0.75rem; display: none; margin-top: -10px; margin-bottom: 10px;">
                  * No hay servicio en fines de semana.
                </span>
              </div>
              <div class="input-group">
                <label for="hora_inicio">Hora de llegada:</label>
                <input type="time" name="hora_inicio" id="hora_inicio" required />
              </div>
            </div>

            <div class="input-group">
              <label for="motivo">Motivo de la visita:</label>
              <textarea name="motivo" id="motivo" placeholder="Describe brevemente el motivo de tu visita..." required></textarea>
            </div>

            <p class="section-label"><i class="fas fa-id-card"></i> Identificación</p>

            <div class="input-group">
              <label for="tipo_doc">Tipo de documento:</label>
              <select name="tipo_doc" id="tipo_doc" required>
                <option value="" disabled selected>Selecciona...</option>
                <option value="INE">INE</option>
                <option value="Pasaporte">Pasaporte</option>
                <option value="Credencial escolar">Credencial escolar</option>
                <option value="Licencia">Licencia de conducir</option>
              </select>
            </div>

            <div class="input-group">
              <label for="documento">Archivo de identificación (PDF, JPG, PNG — máx 5MB):</label>
              <input type="file" name="documento" id="documento" accept=".pdf,.jpg,.jpeg,.png" required />
            </div>

            <button type="submit" class="btn-submit-cita" id="submitBtn">
              <i class="fas fa-paper-plane"></i> Enviar Solicitud de Cita
            </button>
          </form>
        </div>

        <div class="qr-side" id="form-result">
          <div class="placeholder">
            <span class="icon">📅</span>
            <p>Los detalles de tu confirmación aparecerán aquí al finalizar el registro.</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- Modal de resultado -->
  <div class="resultado-modal-overlay" id="resultado-modal">
    <div class="resultado-modal">
      <div class="resultado-icon" id="resultado-icon"></div>
      <h3 id="resultado-titulo"></h3>
      <p id="resultado-mensaje"></p>
      <button class="btn-cerrar-modal" id="btn-cerrar-modal">Cerrar</button>
    </div>
  </div>

  <ChatWidget />
  <Footer />
</Layout>

<style>
  .form-container {
    padding: 3rem 0;
  }

  .card-grid { 
    display: grid; 
    grid-template-columns: 1.5fr 1fr; 
    gap: 30px; 
    background: var(--card-bg, white); 
    padding: 40px; 
    border-radius: var(--radius-lg, 16px);
    box-shadow: var(--shadow-md);
    border: 1px solid var(--color-border, #eee);
  }

  .form-side h2 {
    color: var(--color-primary);
    margin-bottom: 8px;
    -webkit-text-fill-color: var(--color-primary);
    background: none;
  }

  .form-side > p {
    color: var(--text-muted);
    margin-bottom: 24px;
  }

  .form-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .form-row input, .form-row select {
    flex: 1;
    min-width: 140px;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    margin-bottom: 15px;
    width: 100%;
  }

  .input-group label {
    font-size: 0.75rem;
    margin-bottom: 6px;
    color: var(--color-navy-deep);
  }

  input, select, textarea {
    width: 100%;
    padding: 12px 16px;
    margin-bottom: 15px;
  }

  textarea {
    resize: vertical;
    min-height: 80px;
    font-family: var(--font-body, 'DM Sans', sans-serif);
  }

  .section-label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-accent, #00A688);
    letter-spacing: 0.06em;
    margin: 20px 0 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section-label i {
    font-size: 0.9rem;
  }

  .btn-submit-cita:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .qr-side { 
    display: flex; 
    flex-direction: column; 
    align-items: center; 
    justify-content: center; 
    border-left: 2px dashed var(--divider, #eee); 
    text-align: center;
    padding: 20px;
  }

  .placeholder .icon { font-size: 4rem; display: block; margin-bottom: 10px; }

  /* Botón Enviar Solicitud */
  .btn-submit-cita {
    width: 100%;
    padding: 14px 28px;
    border: none;
    border-radius: var(--radius-sm, 8px);
    background: linear-gradient(135deg, #00A688 0%, #00C9A4 50%, #00A688 100%);
    background-size: 200% 200%;
    color: white;
    font-family: var(--font-heading, 'Outfit', sans-serif);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.03em;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(0, 166, 136, 0.3);
    position: relative;
    overflow: hidden;
    margin-top: 8px;
  }

  .btn-submit-cita:hover {
    background-position: 100% 0;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 166, 136, 0.45);
  }

  .btn-submit-cita:active {
    transform: translateY(0);
  }

  .btn-submit-cita::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transition: left 0.5s ease;
  }

  .btn-submit-cita:hover::before {
    left: 100%;
  }

  /* Modal de resultado */
  .resultado-modal-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    z-index: 99999;
    justify-content: center;
    align-items: center;
  }

  .resultado-modal-overlay.activo {
    display: flex;
  }

  .resultado-modal {
    background: var(--color-card, #fff);
    border-radius: var(--radius-lg, 16px);
    padding: 40px 50px;
    text-align: center;
    max-width: 420px;
    width: 90%;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
    animation: modalEntra 0.35s ease-out;
  }

  @keyframes modalEntra {
    from { opacity: 0; transform: scale(0.85) translateY(20px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .resultado-icon {
    font-size: 4rem;
    margin-bottom: 16px;
  }

  .resultado-icon.exito {
    color: #28a745;
  }

  .resultado-icon.error {
    color: #dc3545;
  }

  .resultado-modal h3 {
    margin-bottom: 10px;
    font-size: 1.3rem;
    color: var(--color-primary, #0F4C75);
    -webkit-text-fill-color: var(--color-primary, #0F4C75);
    background: none;
  }

  .resultado-modal p {
    color: var(--color-text-light, #718096);
    font-size: 0.95rem;
    margin-bottom: 24px;
  }

  .btn-cerrar-modal {
    padding: 10px 32px;
    border: none;
    border-radius: var(--radius-sm, 8px);
    background: linear-gradient(135deg, #00A688, #00C9A4);
    color: white;
    font-family: var(--font-heading, 'Outfit', sans-serif);
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 14px rgba(0, 166, 136, 0.25);
  }

  .btn-cerrar-modal:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 166, 136, 0.4);
  }

  @media (max-width: 768px) {
    .card-grid { grid-template-columns: 1fr; }
    .qr-side { border-left: none; border-top: 2px dashed var(--divider, #eee); padding-top: 30px; }
  }
</style>

<script>
  import { endpoints } from '../config/api.js';

  function initSolicitudForm() {
    const form = document.getElementById('appointment-form') as HTMLFormElement;
    const result = document.getElementById('form-result');
    const dateInput = document.getElementById('fecha') as HTMLInputElement;
    const dateError = document.getElementById('date-error');
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

    // --- CARGAR DEPARTAMENTOS DESDE API ---
    async function cargarDepartamentos() {
      try {
        const res = await fetch(endpoints.departamentos, {
          headers: { "ngrok-skip-browser-warning": "true" }
        });
        const json = await res.json();
        const select = document.getElementById('depto_id') as HTMLSelectElement;
        if (select) {
          select.innerHTML = '<option value="" disabled selected>Selecciona un departamento...</option>';
          json.data.forEach((d: { id: number; nombre: string; ubicacion: string }) => {
            select.innerHTML += `<option value="${d.id}">${d.nombre} — ${d.ubicacion}</option>`;
          });
        }
      } catch (err) {
        console.error("Error cargando departamentos:", err);
        const select = document.getElementById('depto_id') as HTMLSelectElement;
        if (select) {
          select.innerHTML = '<option value="" disabled selected>Error al cargar departamentos</option>';
        }
      }
    }

    cargarDepartamentos();

    // --- LÓGICA DE RESTRICCIÓN DE FECHAS ---
    if (dateInput) {
      const today = new Date().toISOString().split('T')[0];
      dateInput.setAttribute('min', today);

      dateInput.addEventListener('change', (e) => {
        const target = e.target as HTMLInputElement;
        const dateParts = target.value.split('-');
        const selectedDate = new Date(parseInt(dateParts[0]), parseInt(dateParts[1]) - 1, parseInt(dateParts[2]));
        const day = selectedDate.getDay();

        if (day === 0 || day === 6) {
          alert('El campus UTSJR no recibe visitas en fines de semana. Por favor selecciona un día de Lunes a Viernes.');
          target.value = '';
          if (dateError) dateError.style.display = 'block';
        } else {
          if (dateError) dateError.style.display = 'none';
        }
      });
    }

    // --- MODAL HELPERS ---
    const modal = document.getElementById('resultado-modal');
    const modalIconEl = document.getElementById('resultado-icon');
    const modalTitulo = document.getElementById('resultado-titulo');
    const modalMensaje = document.getElementById('resultado-mensaje');
    const btnCerrar = document.getElementById('btn-cerrar-modal');

    function mostrarModal(tipo: 'exito' | 'error', titulo: string, mensaje: string) {
      if (!modal || !modalIconEl || !modalTitulo || !modalMensaje) return;
      modalIconEl.className = 'resultado-icon ' + tipo;
      if (tipo === 'exito') {
        modalIconEl.innerHTML = '<i class="fas fa-check-circle"></i>';
      } else {
        modalIconEl.innerHTML = '<i class="fas fa-times-circle"></i>';
      }
      modalTitulo.textContent = titulo;
      modalMensaje.textContent = mensaje;
      modal.classList.add('activo');
    }

    btnCerrar?.addEventListener('click', () => {
      modal?.classList.remove('activo');
    });

    modal?.addEventListener('click', (e) => {
      if (e.target === modal) modal.classList.remove('activo');
    });

    // --- LÓGICA DE ENVÍO A LA API ---
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!submitBtn) return;

      submitBtn.disabled = true;
      submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Registrando...';

      const formData = new FormData(form);
      const nombre = formData.get('nombre') as string;
      const apellido = formData.get('apellido_paterno') as string;
      const fecha = formData.get('fecha') as string;
      const motivo = formData.get('motivo') as string;

      try {
        const res = await fetch(endpoints.register, {
          method: 'POST',
          headers: { "ngrok-skip-browser-warning": "true" },
          body: formData
        });

        const json = await res.json();

        if (res.ok) {
          if (result) {
            result.innerHTML = `
              <div class="success-msg">
                <div style="font-size: 3rem;"><i class="fas fa-check-circle" style="color: #28a745;"></i></div>
                <h3>Solicitud Enviada</h3>
                <p>Gracias, <strong>${nombre} ${apellido}</strong>.</p>
                <hr style="margin: 15px 0; opacity: 0.2;">
                <p>Tu visita para el día <strong>${fecha}</strong> ha sido registrada.</p>
                <p><small>Recibirás un correo de confirmación cuando sea aprobada.</small></p>
                <button onclick="window.location.reload()" style="margin-top:20px; cursor:pointer; padding: 10px 24px; border-radius:8px; border:none; background: linear-gradient(135deg, #00A688, #00C9A4); color: white; font-weight: 600;">Nueva Solicitud</button>
              </div>
            `;
          }
          mostrarModal('exito', 'Datos enviados correctamente', 'Tu solicitud de visita ha sido registrada exitosamente.');
          form.reset();
          cargarDepartamentos();
        } else {
          mostrarModal('error', 'Error al enviar', json.error || 'No se pudieron enviar los datos. Intenta nuevamente.');
        }
      } catch (err) {
        mostrarModal('error', 'Error de conexión', 'No se pudo conectar con el servidor. Verifica tu conexión e intenta nuevamente.');
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="fas fa-paper-plane"></i> Enviar Solicitud de Cita';
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initSolicitudForm);
  document.addEventListener('astro:page-load', initSolicitudForm);
</script>
