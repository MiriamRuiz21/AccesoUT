---
import ThemeToggle from './ThemeToggle.astro';

const currentPath = Astro.url.pathname;
---

<header class="ut-header">
  <div class="top-bar">
    <div class="container top-content">
      <div class="logos">
        <img src="/logo-gobierno.png" alt="" class="logo-img" />
        <div class="separator"></div>
        <span class="uni-name">UT <strong>San Juan</strong></span>
      </div>
      <div class="top-links">
        <a href="https://www.utsjr.edu.mx" target="_blank">Portal UTSJR</a>
      </div>
    </div>
  </div>

  <nav class="main-nav">
    <div class="container nav-container">
      <button class="hamburger" id="hamburger-btn" aria-label="Abrir menú" aria-expanded="false">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>

      <ul class="nav-links" id="nav-links">
        <li class={currentPath === '/' ? 'active' : ''}><a href="/">Inicio</a></li>
        <li class={currentPath === '/solicitud-cita' || currentPath === '/solicitud-cita/' ? 'active' : ''}><a href="/solicitud-cita">Solicitud de Cita</a></li>
        <li class={currentPath === '/consultar-visita' || currentPath === '/consultar-visita/' ? 'active' : ''}><a href="/consultar-visita">Consultar Visita</a></li>
        <li class={currentPath === '/instrucciones' || currentPath === '/instrucciones/' ? 'active' : ''}><a href="/instrucciones">Instrucciones de Acceso</a></li>
        <li class={currentPath === '/directorio' || currentPath === '/directorio/' ? 'active' : ''}><a href="/directorio">Directorio</a></li>
      </ul>
      
      <div class="nav-actions">
        <ThemeToggle />
      </div>
    </div>
  </nav>
</header>

<style>
  .ut-header {
    width: 100%;
    position: sticky;
    top: 4px; /* espacio para la línea institucional */
    z-index: 9999;
    font-family: var(--font-heading, 'Outfit', sans-serif);
  }

  /* ── BARRA SUPERIOR ── */
  .top-bar {
    background: var(--color-card, #ffffff);
    padding: 10px 0;
    border-bottom: 1px solid var(--color-border, #e2e8f0);
    transition: background-color 0.3s;
    box-shadow: var(--shadow-sm);
  }

  .top-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .logos {
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .logo-img {
    height: 30px;
    width: auto;
    object-fit: contain;
  }

  .separator {
    width: 1px;
    height: 24px;
    background: var(--color-border, #cccccc);
  }

  .uni-name {
    font-size: 1.05rem;
    color: var(--color-text, #333333);
    letter-spacing: -0.3px;
    font-weight: 400;
  }

  .uni-name strong {
    color: var(--color-primary, #0F4C75);
    font-weight: 700;
    -webkit-text-fill-color: var(--color-primary, #0F4C75);
  }

  .top-links {
    display: flex;
    gap: 20px;
  }

  .top-links a {
    font-size: 13px;
    color: var(--color-text-muted, #A0AEC0);
    text-decoration: none;
    transition: color 0.25s;
    font-weight: 500;
  }

  .top-links a:hover {
    color: var(--color-accent, #00A688);
  }

  /* ── BARRA PRINCIPAL (Gradiente institucional) ── */
  .main-nav {
    background: linear-gradient(135deg, var(--color-accent, #00A688) 0%, var(--color-accent-dark, #008A70) 100%);
    height: 50px;
    position: relative;
    box-shadow: 0 4px 20px rgba(0, 166, 136, 0.2);
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    height: 100%;
  }

  .nav-links {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    height: 100%;
  }

  .nav-links li {
    display: flex;
    align-items: center;
    padding: 0 20px;
    height: 100%;
    position: relative;
    transition: background 0.3s;
  }

  .nav-links li::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%) scaleX(0);
    width: 70%;
    height: 3px;
    background: white;
    border-radius: 3px 3px 0 0;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .nav-links li:hover::after,
  .nav-links li.active::after {
    transform: translateX(-50%) scaleX(1);
  }

  .nav-links li:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .nav-links li.active {
    background: rgba(0, 0, 0, 0.12);
  }

  .nav-links a {
    color: #ffffff;
    text-decoration: none;
    font-size: 13.5px;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .nav-actions {
    display: flex;
    align-items: center;
  }

  /* ── HAMBURGER ── */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    z-index: 10;
  }

  .hamburger-line {
    width: 24px;
    height: 2.5px;
    background: white;
    border-radius: 3px;
    transition: transform 0.3s, opacity 0.3s;
  }

  .hamburger.open .hamburger-line:nth-child(1) {
    transform: translateY(7.5px) rotate(45deg);
  }
  .hamburger.open .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .hamburger.open .hamburger-line:nth-child(3) {
    transform: translateY(-7.5px) rotate(-45deg);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .top-links { display: none; }

    .hamburger { display: flex; }

    .nav-links {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      height: auto;
      background: linear-gradient(180deg, var(--color-accent-dark, #008A70), #006B57);
      box-shadow: 0 8px 24px rgba(0,0,0,0.15);
      overflow: hidden;
      max-height: 0;
      transition: max-height 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .nav-links.open { max-height: 300px; }

    .nav-links li {
      padding: 0;
      height: auto;
    }

    .nav-links li::after { display: none; }

    .nav-links a {
      display: block;
      padding: 14px 24px;
      font-size: 14px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .nav-links li:hover {
      background: rgba(255,255,255,0.08);
    }
  }
</style>

<script>
  function initHamburger() {
    const btn = document.getElementById('hamburger-btn');
    const navLinks = document.getElementById('nav-links');

    btn?.addEventListener('click', () => {
      btn.classList.toggle('open');
      navLinks?.classList.toggle('open');
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
    });

    navLinks?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        btn?.classList.remove('open');
        navLinks.classList.remove('open');
        btn?.setAttribute('aria-expanded', 'false');
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initHamburger);
  document.addEventListener('astro:page-load', initHamburger);
</script>
